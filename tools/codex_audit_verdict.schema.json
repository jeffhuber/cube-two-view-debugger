{
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "verdict", "summary", "findings"],
  "properties": {
    "schema": {
      "type": "string",
      "enum": ["cubesnap.codexAudit.v1"]
    },
    "verdict": {
      "type": "string",
      "enum": ["pass", "blocked"]
    },
    "summary": {
      "type": "string"
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["severity", "title", "file", "line", "detail"],
        "properties": {
          "severity": {
            "type": "string",
            "enum": ["P0", "P1", "P2", "P3"]
          },
          "title": {
            "type": "string"
          },
          "file": {
            "type": "string"
          },
          "line": {
            "type": "integer"
          },
          "detail": {
            "type": "string"
          }
        }
      }
    }
  }
}
